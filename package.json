{
  "name": "@mbtech-nl/lzo1x",
  "version": "0.1.0",
  "description": "Pure-TypeScript clean-room implementation of LZO1X-1 compression and decompression, isomorphic (Node + browser)",
  "license": "MIT",
  "author": "Mannes Brak",
  "homepage": "https://github.com/mbtech-nl/lzo1x",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbtech-nl/lzo1x.git"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "prettier": "@mbtech-nl/prettier-config",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@mbtech-nl/eslint-config": "^1.0.1",
    "@mbtech-nl/prettier-config": "^1.0.0",
    "@mbtech-nl/tsconfig": "^1.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "node-gyp": "^12.3.0",
    "prettier": "^3.0.0",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "lzo": "^0.4.11"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mannes"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mannes"
    }
  ]
}
